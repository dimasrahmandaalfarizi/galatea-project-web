---
import BaseLayout from '../layouts/BaseLayout.astro';

const videoUrl = 'https://d8j0ntlcm91z4.cloudfront.net/user_38xzZboKViGWJOttwIXH07lWA1P/hf_20260328_083109_283f3553-e28f-428b-a723-d639c617eb2b.mp4';

const stats = [
  { value: 67.8, suffix: 'jt ton', label: 'Sampah diproduksi Indonesia per tahun', decimals: 1 },
  { value: 60, suffix: '%', label: 'Sampah organik yang bisa diolah', decimals: 0 },
  { value: 300, suffix: '+', label: 'Kota perlu perbaikan sistem sampah', decimals: 0 },
  { value: 2030, suffix: '', label: 'Target Indonesia bebas sampah', decimals: 0 },
];

const sections = [
  {
    href: '/about',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>',
    title: 'Tentang Program',
    desc: 'Kenali tujuan dan latar belakang program edukasi pengelolaan sampah KWN ini.',
    badge: 'KWN 2026',
  },
  {
    href: '/infographics',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>',
    title: 'Infografis',
    desc: 'Visualisasi data dan cara pemilahan sampah yang mudah dipahami.',
    badge: 'Edukasi',
  },
  {
    href: '/poster',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>',
    title: 'Poster Edukasi',
    desc: 'Kumpulan poster informatif tentang jenis-jenis sampah dan pengelolaannya.',
    badge: 'Visual',
  },
  {
    href: '/kuesioner',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>',
    title: 'Kuesioner',
    desc: 'Ikuti kuesioner dan lihat grafik hasil survei dari 30 responden.',
    badge: 'Survei',
  },
];
---

<BaseLayout title="Beranda" description="Galatea — Edukasi pengelolaan sampah untuk Indonesia yang lebih hijau. Program Kewarganegaraan 2026.">

  <!-- ═══════════════════════════════════ HERO ═══════════════════════════════════ -->
  <section class="relative min-h-screen w-full overflow-hidden flex flex-col justify-center bg-[#0f1a14]">
    <!-- Video Background (Full Screen) -->
    <div class="absolute inset-0 z-0">
      <video
        id="hero-video"
        class="absolute inset-0 w-full h-full object-cover opacity-0"
        muted
        playsinline
        preload="auto"
      >
        <source src={videoUrl} type="video/mp4" />
      </video>

      <!-- Gradient overlays for readability -->
      <div class="absolute inset-0 bg-gradient-to-b from-[#0f1a14]/80 via-[#0f1a14]/40 to-[#0f1a14]"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-[#0f1a14]/80 via-transparent to-[#0f1a14]/80"></div>
    </div>

    <!-- Hero Content -->
    <div id="hero-content" class="relative z-10 flex flex-col items-center justify-center text-center px-6 pt-20 pb-24 h-full">
      <!-- Badge -->
      <div class="section-badge mb-8 hero-item opacity-0" style="transform: translateY(20px)">
        <span class="w-2 h-2 rounded-full bg-primary-400 animate-pulse"></span>
        Program Kewarganegaraan 2026
      </div>

      <!-- Headline -->
      <h1 class="font-bold text-5xl sm:text-7xl md:text-8xl max-w-5xl leading-[0.95] tracking-tight text-white hero-item opacity-0" style="letter-spacing:-2px; transform: translateY(30px)">
        Jaga Bumi,
        <span class="text-primary-500"> Mulai dari</span>
        <br />Sampahmu
      </h1>

      <!-- Subheadline -->
      <p class="text-gray-300 text-lg sm:text-xl max-w-2xl mt-8 leading-relaxed hero-item opacity-0 font-light" style="transform: translateY(20px)">
        Edukasi pemilahan sampah adalah langkah pertama menuju Indonesia yang lebih bersih dan berkelanjutan.
        Mari belajar bersama dan wujudkan perubahan nyata.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row items-center gap-4 mt-12 hero-item opacity-0" style="transform: translateY(20px)">
        <a href="/kuesioner" class="btn-primary hover:scale-105 transition-transform duration-300">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
          </svg>
          Ikuti Kuesioner
        </a>
        <a href="/infographics" class="btn-outline bg-white/5 backdrop-blur-md hover:bg-white/10 hover:scale-105 transition-transform duration-300">
          Lihat Infografis
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>

      <!-- Scroll Indicator -->
      <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 hero-item opacity-0" style="transform: translateY(20px)">
        <span class="text-gray-500 text-xs uppercase tracking-widest font-semibold">Scroll</span>
        <div class="w-px h-12 bg-gradient-to-b from-primary-500/80 to-transparent"></div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════ MARQUEE (TICKER) ═══════════════════════════════════ -->
  <div class="relative bg-primary-600 border-y border-primary-500 overflow-hidden flex items-center py-3 z-20">
    <div class="flex whitespace-nowrap animate-marquee items-center text-primary-950 font-bold text-sm tracking-widest uppercase">
      <span class="mx-4">Kewarganegaraan 2026</span> <span class="mx-4">✦</span>
      <span class="mx-4">Edukasi Pemilahan Sampah</span> <span class="mx-4">✦</span>
      <span class="mx-4">Reduce</span> <span class="mx-4">✦</span>
      <span class="mx-4">Reuse</span> <span class="mx-4">✦</span>
      <span class="mx-4">Recycle</span> <span class="mx-4">✦</span>
      <span class="mx-4">Galatea</span> <span class="mx-4">✦</span>
      <span class="mx-4">Kewarganegaraan 2026</span> <span class="mx-4">✦</span>
      <span class="mx-4">Edukasi Pemilahan Sampah</span> <span class="mx-4">✦</span>
      <span class="mx-4">Reduce</span> <span class="mx-4">✦</span>
      <span class="mx-4">Reuse</span> <span class="mx-4">✦</span>
      <span class="mx-4">Recycle</span> <span class="mx-4">✦</span>
      <span class="mx-4">Galatea</span> <span class="mx-4">✦</span>
    </div>
    <!-- Duplicate for seamless looping -->
    <div class="flex whitespace-nowrap animate-marquee items-center text-primary-950 font-bold text-sm tracking-widest uppercase absolute top-3" aria-hidden="true" style="animation-delay: -15s">
      <span class="mx-4">Kewarganegaraan 2026</span> <span class="mx-4">✦</span>
      <span class="mx-4">Edukasi Pemilahan Sampah</span> <span class="mx-4">✦</span>
      <span class="mx-4">Reduce</span> <span class="mx-4">✦</span>
      <span class="mx-4">Reuse</span> <span class="mx-4">✦</span>
      <span class="mx-4">Recycle</span> <span class="mx-4">✦</span>
      <span class="mx-4">Galatea</span> <span class="mx-4">✦</span>
      <span class="mx-4">Kewarganegaraan 2026</span> <span class="mx-4">✦</span>
      <span class="mx-4">Edukasi Pemilahan Sampah</span> <span class="mx-4">✦</span>
      <span class="mx-4">Reduce</span> <span class="mx-4">✦</span>
      <span class="mx-4">Reuse</span> <span class="mx-4">✦</span>
      <span class="mx-4">Recycle</span> <span class="mx-4">✦</span>
      <span class="mx-4">Galatea</span> <span class="mx-4">✦</span>
    </div>
  </div>

  <!-- ═══════════════════════════════════ STATS ═══════════════════════════════════ -->
  <section class="py-32 relative">
    <div class="absolute inset-0 bg-[#0f1a14] z-0"></div>
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-4xl h-px bg-gradient-to-r from-transparent via-white/10 to-transparent z-10"></div>
    
    <div class="section-container relative z-10">
      <div class="text-center mb-20 scroll-fade-up opacity-0">
        <span class="section-badge">Fakta & Data</span>
        <h2 class="section-heading text-white mt-6 text-5xl md:text-6xl">Kondisi Sampah <br/><span class="text-primary-500">Indonesia</span></h2>
      </div>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
        {stats.map((stat) => (
          <div class="p-8 text-center group scroll-stagger opacity-0 relative overflow-hidden rounded-3xl border border-white/5 bg-white/[0.02] backdrop-blur-xl hover:bg-white/[0.04] transition-colors duration-500">
            <div class="absolute inset-0 bg-gradient-to-br from-primary-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            <div
              class="stat-num text-5xl lg:text-6xl font-bold text-primary-400 mb-4 tracking-tighter"
              data-target={stat.value}
              data-suffix={stat.suffix}
              data-decimals={stat.decimals}
            >
              0{stat.suffix}
            </div>
            <p class="text-gray-400 text-sm leading-relaxed font-light">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════ BENTO GRID SECTIONS ═══════════════════════════════════ -->
  <section class="py-32 relative bg-[#050806]">
    <!-- Clean minimal grid, strictly utilitarian -->
    <div class="absolute inset-0 z-0 opacity-20" style="background-image: linear-gradient(#1a2e22 1px, transparent 1px), linear-gradient(to right, #1a2e22 1px, #050806 1px); background-size: 64px 64px;"></div>

    <div class="section-container relative z-10">
      <div class="flex flex-col md:flex-row justify-between items-end mb-16 scroll-fade-up opacity-0">
        <div>
          <h2 class="section-heading text-white text-4xl md:text-5xl">Arsitektur <span class="text-primary-500">Program</span></h2>
          <p class="text-gray-400 mt-4 max-w-xl font-light">Eksplorasi setiap modul edukasi yang telah kami rancang untuk memvalidasi pemahaman manajemen limbah.</p>
        </div>
      </div>
      
      <!-- Asymmetric Bento Grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 md:grid-rows-2 gap-4 auto-rows-[minmax(250px,auto)]">
        
        <!-- Bento 1: Infografis (Wide) -->
        <a href="/infographics" class="md:col-span-2 group relative p-8 rounded-2xl border border-white/10 bg-[#0f1a14] hover:bg-[#132a1f] transition-colors duration-300 overflow-hidden flex flex-col justify-between">
          <div class="absolute top-0 right-0 p-8 opacity-20 group-hover:opacity-100 transition-opacity duration-500">
            <!-- Functional abstract chart graphic -->
            <div class="flex items-end gap-2 h-24">
              <div class="w-4 bg-primary-500 h-1/3"></div>
              <div class="w-4 bg-primary-400 h-2/3"></div>
              <div class="w-4 bg-primary-300 h-full"></div>
            </div>
          </div>
          <div class="mb-12">
            <div class="w-10 h-10 mb-4 text-primary-400">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
            </div>
            <span class="text-xs text-primary-300 bg-primary-900/40 border border-primary-800/50 px-2 py-1 rounded font-mono uppercase tracking-wider mb-3 inline-block">Data Center</span>
            <h3 class="text-white font-semibold text-2xl md:text-3xl tracking-tight mb-2">Pusat Infografis</h3>
            <p class="text-gray-400 font-light max-w-sm">Akses visualisasi data aktual terkait komposisi sampah Indonesia secara real-time.</p>
          </div>
          <div class="flex items-center text-primary-400 text-sm font-medium group-hover:translate-x-2 transition-transform w-max">
            Akses Data <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-1"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </div>
        </a>

        <!-- Bento 2: Poster (Tall) -->
        <a href="/poster" class="md:row-span-2 group relative p-8 rounded-2xl border border-white/10 bg-[#0f1a14] hover:bg-[#132a1f] transition-colors duration-300 overflow-hidden flex flex-col">
          <div class="mb-auto">
            <div class="w-10 h-10 mb-4 text-primary-400">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
            </div>
            <span class="text-xs text-primary-300 bg-primary-900/40 border border-primary-800/50 px-2 py-1 rounded font-mono uppercase tracking-wider mb-3 inline-block">Materi Edukasi</span>
            <h3 class="text-white font-semibold text-2xl tracking-tight mb-2">Galeri Poster</h3>
            <p class="text-gray-400 font-light mb-8">Kumpulan aset grafis beresolusi tinggi terkait jenis limbah dan tata cara pemilahannya.</p>
          </div>
          
          <div class="w-full aspect-[4/5] bg-[#1a2e22] border border-white/5 rounded-xl shadow-2xl shadow-black/50 rotate-3 group-hover:rotate-0 transition-transform duration-500 p-4">
             <div class="w-full h-full border border-primary-500/30 flex flex-col">
               <div class="h-1/2 bg-primary-900/20 w-full"></div>
               <div class="p-3 space-y-2">
                 <div class="h-2 w-1/2 bg-white/20 rounded"></div>
                 <div class="h-2 w-3/4 bg-white/10 rounded"></div>
               </div>
             </div>
          </div>
        </a>

        <!-- Bento 3: About -->
        <a href="/about" class="group p-8 rounded-2xl border border-white/10 bg-[#0f1a14] hover:bg-[#132a1f] transition-colors duration-300 flex flex-col justify-between">
          <div>
            <div class="flex items-center justify-between mb-4">
              <span class="text-xs text-primary-300 bg-primary-900/40 border border-primary-800/50 px-2 py-1 rounded font-mono uppercase tracking-wider">Latar Belakang</span>
              <div class="w-8 h-8 text-primary-400">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
            </div>
            <h3 class="text-white font-semibold text-xl tracking-tight mb-2">Tentang Program</h3>
            <p class="text-gray-400 text-sm font-light leading-relaxed">Objektif, target, dan metodologi program tugas Kewarganegaraan 2026.</p>
          </div>
        </a>

        <!-- Bento 4: Kuesioner -->
        <a href="/kuesioner" class="group p-8 rounded-2xl border border-primary-500/30 bg-[#0f1a14] hover:bg-primary-900/20 transition-colors duration-300 flex flex-col justify-between relative overflow-hidden">
          <div class="absolute bottom-0 right-0 w-32 h-32 bg-primary-500/10 rounded-full blur-2xl group-hover:bg-primary-500/20 transition-colors"></div>
          <div class="relative z-10">
            <div class="flex items-center justify-between mb-4">
              <span class="text-xs text-primary-300 bg-primary-900/40 border border-primary-800/50 px-2 py-1 rounded font-mono uppercase tracking-wider">Validasi Data</span>
              <div class="w-8 h-8 text-primary-400">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
              </div>
            </div>
            <h3 class="text-white font-semibold text-xl tracking-tight mb-2">Survei Kesadaran</h3>
            <p class="text-gray-400 text-sm font-light leading-relaxed mb-4">Uji pemahaman Anda melalui kuesioner dan lihat analitik performa komparatif.</p>
            <div class="inline-flex items-center text-white text-xs font-semibold uppercase tracking-wider bg-primary-600 px-3 py-1.5 rounded-full hover:bg-primary-500 transition-colors">
              Mulai Tes
            </div>
          </div>
        </a>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════ CTA BANNER ═══════════════════════════════════ -->
  <section class="py-32 bg-[#0f1a14]">
    <div class="section-container">
      <div
        class="relative overflow-hidden rounded-[2.5rem] bg-gradient-to-br from-[#132a1f] to-[#0f1a14] border border-primary-800/30 p-12 md:p-20 text-center scroll-scale-up opacity-0"
      >
        <div class="relative z-10 flex flex-col items-center">
          <span class="section-badge mb-6">Ambil Bagian</span>
          <h2 class="section-heading text-white text-5xl md:text-6xl lg:text-7xl">
            Mulai Perubahan <br/><span class="text-primary-500">Sekarang</span>
          </h2>
          <p class="text-gray-300 mt-6 max-w-2xl text-lg font-light leading-relaxed">
            Isi kuesioner kami, pelajari cara memilah sampah yang benar, dan jadilah bagian dari gerakan pengelolaan sampah yang lebih baik.
          </p>
          <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mt-12">
            <a href="/kuesioner" class="btn-primary px-8 py-4 text-lg hover:scale-105 transition-transform duration-300">
              Ikuti Kuesioner
            </a>
            <a href="/infographics" class="btn-outline px-8 py-4 text-lg bg-white/5 hover:bg-white/10 hover:scale-105 transition-transform duration-300">
              Lihat Infografis
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  import { animate, inView, stagger } from "motion";

  // 1. Hero Animations (Video Fade + Text Stagger)
  const video = document.getElementById('hero-video') as HTMLVideoElement;
  if (video) {
    // Fade in video smoothly when loaded
    video.addEventListener('canplaythrough', () => {
      animate(video, { opacity: 1 }, { duration: 1.5, easing: "ease-out" });
    });
    // Fallback if already loaded
    if (video.readyState >= 3) {
      animate(video, { opacity: 1 }, { duration: 1.5, easing: "ease-out" });
    }
    
    // Auto-loop video smoothly (fade out at end, replay, fade in)
    const FADE_DURATION = 0.8;
    setInterval(() => {
      if (video.duration && video.currentTime > video.duration - FADE_DURATION) {
        animate(video, { opacity: 0 }, { duration: FADE_DURATION });
      }
    }, 100);

    video.addEventListener('ended', () => {
      video.currentTime = 0;
      video.play();
      animate(video, { opacity: 1 }, { duration: FADE_DURATION });
    });
    
    video.play().catch(() => {});
  }

  // Animate hero text items on load
  const heroItems = Array.from(document.querySelectorAll('.hero-item'));
  if (heroItems.length) {
    animate(
      heroItems, 
      { opacity: 1, y: 0 }, 
      { 
        duration: 0.8, 
        delay: stagger(0.15, { startDelay: 0.2 }),
        easing: [0.17, 0.55, 0.55, 1] // Custom spring-like curve
      }
    );
  }

  // 2. Scroll Animations
  // Fade Up Elements
  inView('.scroll-fade-up', (element) => {
    animate(element, { opacity: 1, y: [-40, 0] }, { duration: 0.8, easing: "ease-out" });
  });

  // Scale Up Element (CTA Banner)
  inView('.scroll-scale-up', (element) => {
    animate(element, { opacity: 1, scale: [0.95, 1] }, { duration: 0.8, easing: [0.17, 0.55, 0.55, 1] });
  });

  // Staggered Grids
  inView('.grid', (element) => {
    const items = Array.from(element.querySelectorAll('.scroll-stagger'));
    if (items.length) {
      animate(
        items, 
        { opacity: 1, y: [-30, 0] }, 
        { duration: 0.6, delay: stagger(0.1), easing: "ease-out" }
      );
    }
  });

  // 3. Number Counter Animation (using Motion)
  inView('.stat-num', (element) => {
    const el = element as HTMLElement;
    if (!el) return;
    const target = parseFloat(el.dataset.target || '0');
    const suffix = el.dataset.suffix || '';
    const decimals = parseInt(el.dataset.decimals || '0');
    
    animate(0, target, {
      duration: 2,
      easing: "ease-out",
      onUpdate: (latest) => {
        el.textContent = latest.toFixed(decimals) + suffix;
      }
    });
  });
</script>
