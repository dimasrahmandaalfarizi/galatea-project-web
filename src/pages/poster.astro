---
import BaseLayout from '../layouts/BaseLayout.astro';

const posters = [
  { id: 1, title: 'Cara Memilah Sampah Organik', category: 'Organik', color: 'from-green-900/60 to-green-700/20', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>', bg: '#1a2f1e', desc: 'Panduan lengkap memilah sampah organik dari sumber rumah tangga.' },
  { id: 2, title: 'Sampah Plastik & Cara Daur Ulang', category: 'Anorganik', color: 'from-blue-900/60 to-blue-700/20', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>', bg: '#1a1e2f', desc: 'Kenali jenis plastik dan cara mendaur ulangnya dengan benar.' },
  { id: 3, title: 'Bahaya Sampah B3 bagi Lingkungan', category: 'B3', color: 'from-red-900/60 to-red-700/20', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m21 16-5.16-5.16a2 2 0 0 0-2.83 0l-5.17 5.17a2 2 0 0 0 0 2.83l5.17 5.17a2 2 0 0 0 2.83 0L21 18.84V16Z"/><path d="m2 16 5.16-5.16a2 2 0 0 1 2.83 0l5.17 5.17a2 2 0 0 1 0 2.83l-5.17 5.17a2 2 0 0 1-2.83 0L2 18.84V16Z"/></svg>', bg: '#2f1a1a', desc: 'Dampak berbahaya sampah B3 dan cara penanganan yang aman.' },
  { id: 4, title: 'Kompos dari Sampah Dapur', category: 'Organik', color: 'from-emerald-900/60 to-emerald-700/20', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>', bg: '#1a2b20', desc: 'Langkah mudah membuat kompos dari limbah dapur sehari-hari.' },
  { id: 5, title: 'Bank Sampah — Solusi Cerdas', category: 'Anorganik', color: 'from-indigo-900/60 to-indigo-700/20', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>', bg: '#1e1a2f', desc: 'Manfaatkan bank sampah untuk menghasilkan nilai ekonomis dari limbah.' },
  { id: 6, title: 'Stop Buang Sampah Sembarangan', category: 'Umum', color: 'from-orange-900/60 to-orange-700/20', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>', bg: '#2f2010', desc: 'Dampak dan konsekuensi membuang sampah tidak pada tempatnya.' },
];
---

<BaseLayout title="Poster Edukasi" description="Kumpulan poster edukasi pemilahan dan pengelolaan sampah dari program KWN Galatea.">

  <!-- Hero -->
  <section class="pt-32 pb-12 relative overflow-hidden">
    <!-- removed glowing background -->
    <div class="section-container relative">
      <div class="max-w-2xl" data-aos>
        <span class="section-badge">Visual Edukasi</span>
        <h1 class="section-heading text-white mt-6">
          Poster <span class="text-primary-500">Edukasi</span>
        </h1>
        <p class="text-gray-400 text-lg mt-4 leading-relaxed">
          Kumpulan poster informatif tentang pemilahan sampah, daur ulang, dan pengelolaan limbah yang benar.
          Desain poster sedang disiapkan — segera hadir!
        </p>
      </div>

      <!-- Filter -->
      <div class="flex flex-wrap gap-3 mt-8" id="filter-btns">
        {['Semua', 'Organik', 'Anorganik', 'B3', 'Umum'].map((cat) => (
          <button
            class="filter-btn px-5 py-2 rounded-full text-sm font-medium transition-all duration-200"
            data-filter={cat === 'Semua' ? 'all' : cat}
          >
            {cat}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Poster Grid -->
  <section class="py-8 pb-24">
    <div class="section-container">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6" id="poster-grid">
        {posters.map((poster, i) => (
          <div
            class="poster-card card-glass overflow-hidden group cursor-pointer hover:scale-[1.03] transition-all duration-300"
            data-category={poster.category}
            data-aos
            data-aos-delay={String((i % 3) * 100)}
            id={`poster-${poster.id}`}
          >
            <!-- Placeholder Image -->
            <div
              class={`relative h-64 bg-gradient-to-br ${poster.color} flex flex-col items-center justify-center`}
              style={`background-color: ${poster.bg}`}
            >
              <div class="w-16 h-16 mb-3 text-white/40 group-hover:text-white group-hover:scale-110 transition-all duration-500" set:html={poster.icon}></div>
              <div class="absolute top-4 right-4">
                <span class="bg-white/10 backdrop-blur-sm text-white text-xs px-3 py-1 rounded-full border border-white/20">
                  {poster.category}
                </span>
              </div>
              <!-- Coming soon overlay -->
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent flex items-end p-4">
                <span class="text-white/70 text-xs font-medium flex items-center">
                  <svg class="w-3 h-3 mr-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                  Poster segera tersedia
                </span>
              </div>
              <!-- Hover overlay -->
              <div class="absolute inset-0 bg-primary-600/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
                <div class="bg-white/20 backdrop-blur-sm rounded-full p-4 border border-white/30">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
                    <circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/>
                  </svg>
                </div>
              </div>
            </div>

            <div class="p-6">
              <h3 class="text-white font-semibold text-lg mb-2 leading-tight">{poster.title}</h3>
              <p class="text-gray-500 text-sm leading-relaxed">{poster.desc}</p>
              <div class="flex items-center justify-between mt-4">
                <span class="text-xs text-primary-400 font-medium">#{poster.category}</span>
                <button class="text-gray-600 hover:text-primary-400 transition-colors text-xs flex items-center gap-1">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3"/>
                  </svg>
                  Unduh
                </button>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Upload notice -->
      <div class="card-glass p-8 mt-12 text-center" data-aos>
        <div class="w-10 h-10 mx-auto mb-4 text-primary-400"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 22h14a2 2 0 0 0 2-2V7.5L14.5 2H6a2 2 0 0 0-2 2v4"/><polyline points="14 2 14 8 20 8"/><path d="M2 15h10"/><path d="M9 18l3-3-3-3"/></svg></div>
        <h3 class="text-white font-semibold text-xl mb-2">Ingin Menambah Poster?</h3>
        <p class="text-gray-400 text-sm max-w-md mx-auto">
          Hubungi tim Galatea untuk mengunggah poster edukasi baru ke galeri ini.
        </p>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .filter-btn {
    background: rgba(255,255,255,0.05);
    color: #9ca3af;
    border: 1px solid rgba(255,255,255,0.1);
  }
  .filter-btn.active, .filter-btn:hover {
    background: rgba(45, 106, 79, 0.4);
    color: #86efac;
    border-color: rgba(82, 183, 136, 0.4);
  }
  .poster-card.hidden-filter {
    display: none;
  }
</style>

<script>
  const btns = document.querySelectorAll('.filter-btn');
  const cards = document.querySelectorAll('.poster-card');

  btns[0]?.classList.add('active');

  btns.forEach((btn) => {
    btn.addEventListener('click', () => {
      btns.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      const filter = (btn as HTMLElement).dataset.filter;
      cards.forEach((card) => {
        const cat = (card as HTMLElement).dataset.category;
        if (filter === 'all' || cat === filter) {
          card.classList.remove('hidden-filter');
        } else {
          card.classList.add('hidden-filter');
        }
      });
    });
  });
</script>
