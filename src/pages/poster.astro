---

<BaseLayout title="Poster Edukasi" description="Kumpulan poster edukasi pemilahan dan pengelolaan sampah dari program KWN Galatea.">

  <!-- Hero -->
  <section class="pt-32 pb-12 relative overflow-hidden">
    <div class="section-container relative">
      <div class="max-w-2xl" data-aos>
        <span class="section-badge">Visual Edukasi</span>
        <h1 class="section-heading text-white mt-6">
          Galeri <span class="text-primary-500">Visual</span>
        </h1>
        <p class="text-gray-400 text-lg mt-4 leading-relaxed">
          Kumpulan poster dan video edukatif mengenai pemilahan sampah, daur ulang, dan pengelolaan limbah yang benar.
        </p>
      </div>

      <!-- Filter -->
      <div class="flex flex-wrap gap-3 mt-8" id="filter-btns">
        {['Semua', 'Organik', 'Anorganik', 'B3', 'Umum', 'Video'].map((cat) => (
          <button
            class="filter-btn px-5 py-2 rounded-full text-sm font-medium transition-all duration-200"
            data-filter={cat === 'Semua' ? 'all' : cat}
          >
            {cat}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Poster Grid -->
  <section class="py-8 pb-24">
    <div class="section-container">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6" id="poster-grid">
        {posters.map((poster, i) => (
          <div
            class="poster-card card-glass overflow-hidden group cursor-pointer hover:-translate-y-2 transition-all duration-300 flex flex-col h-full"
            data-category={poster.category}
            data-aos
            data-aos-delay={String((i % 3) * 100)}
            id={`poster-${poster.id}`}
          >
            <!-- Poster Media (SVG/MP4) -->
            <div
              class={`relative aspect-[4/5] bg-gradient-to-br ${poster.color} flex flex-col items-center justify-center overflow-hidden p-0`}
              style={`background-color: ${poster.bg}`}
            >
              {poster.type === 'video' ? (
                <video src={poster.image} class="w-full h-full object-cover opacity-90 group-hover:opacity-100 group-hover:scale-105 transition-transform duration-500 z-10 drop-shadow-2xl" autoplay loop muted playsinline></video>
              ) : (
                <img src={poster.image} alt={poster.title} class="w-full h-full object-contain p-8 opacity-90 group-hover:opacity-100 group-hover:scale-105 transition-transform duration-500 z-10 drop-shadow-2xl" loading="lazy" />
              )}

              <div class="absolute top-4 right-4 z-20">
                <span class="bg-black/60 backdrop-blur-md text-white text-xs px-3 py-1.5 rounded-full border border-white/10 font-medium tracking-wide">
                  {poster.category}
                </span>
              </div>
              
              <!-- Hover overlay -->
              <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center z-30 backdrop-blur-sm pointer-events-none">
                <div class="bg-primary-600/90 rounded-full p-4 border border-white/20 transform scale-75 group-hover:scale-100 transition-transform duration-300 shadow-xl shadow-primary-500/20">
                  <div set:html={poster.icon} class="w-6 h-6 text-white"></div>
                </div>
              </div>
            </div>

            <div class="p-6 md:p-8 flex flex-col flex-1">
              <h3 class="text-white font-bold text-xl mb-4 leading-tight group-hover:text-primary-400 transition-colors">{poster.title}</h3>
              <p class="text-gray-400 text-sm md:text-base leading-relaxed mb-8 flex-1">{poster.desc}</p>
              <div class="flex items-center justify-between mt-auto pt-5 border-t border-white/10">
                <span class="text-xs text-primary-500 font-semibold tracking-wider uppercase">#{poster.category}</span>
                <a href={poster.image} download class="text-gray-300 hover:text-white bg-white/5 hover:bg-primary-600/50 px-4 py-2.5 rounded-lg transition-all duration-300 text-xs flex items-center gap-2 font-medium border border-white/10 hover:border-primary-500/50">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3"/>
                  </svg>
                  Unduh {poster.type === 'video' ? 'MP4' : 'SVG'}
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Upload notice -->
      <div class="card-glass p-8 mt-12 text-center" data-aos>
        <div class="w-10 h-10 mx-auto mb-4 text-primary-400"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 22h14a2 2 0 0 0 2-2V7.5L14.5 2H6a2 2 0 0 0-2 2v4"/><polyline points="14 2 14 8 20 8"/><path d="M2 15h10"/><path d="M9 18l3-3-3-3"/></svg></div>
        <h3 class="text-white font-semibold text-xl mb-2">Ingin Menambah Poster?</h3>
        <p class="text-gray-400 text-sm max-w-md mx-auto">
          Hubungi tim Galatea untuk mengunggah poster edukasi baru ke galeri ini.
        </p>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .filter-btn {
    background: rgba(255,255,255,0.05);
    color: #9ca3af;
    border: 1px solid rgba(255,255,255,0.1);
  }
  .filter-btn.active, .filter-btn:hover {
    background: rgba(45, 106, 79, 0.4);
    color: #86efac;
    border-color: rgba(82, 183, 136, 0.4);
  }
  .poster-card.hidden-filter {
    display: none;
  }
</style>

<script>
  // @ts-nocheck
  const btns = document.querySelectorAll('.filter-btn');
  const cards = document.querySelectorAll('.poster-card');

  btns[0]?.classList.add('active');

  btns.forEach((btn) => {
    btn.addEventListener('click', () => {
      btns.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      const filter = (btn as HTMLElement).dataset.filter;
      cards.forEach((card) => {
        const cat = (card as HTMLElement).dataset.category;
        if (filter === 'all' || cat === filter) {
          card.classList.remove('hidden-filter');
        } else {
          card.classList.add('hidden-filter');
        }
      });
    });
  });
</script>
