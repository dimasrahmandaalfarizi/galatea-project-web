---
import BaseLayout from '../layouts/BaseLayout.astro';

const galleryItems = [
  { id: 1, title: 'Sosialisasi Pemilahan Sampah', category: 'Sosialisasi', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 11l18-5v12L3 14v-3z"/></svg>', color: 'bg-green-900/40', aspect: 'h-48' },
  { id: 2, title: 'Workshop Komposting', category: 'Workshop', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>', color: 'bg-emerald-900/40', aspect: 'h-64' },
  { id: 3, title: 'Pemasangan Poster di RW', category: 'Aksi Lapangan', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21.5 2v6h-6M2.5 22v-6h6M2 11.5a10 10 0 0 1 18.8-4.3M22 12.5a10 10 0 0 1-18.8 4.2"/></svg>', color: 'bg-teal-900/40', aspect: 'h-56' },
  { id: 4, title: 'Survei Kuesioner Warga', category: 'Survei', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>', color: 'bg-blue-900/40', aspect: 'h-48' },
  { id: 5, title: 'Pemilahan Sampah Bersama', category: 'Aksi Lapangan', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>', color: 'bg-indigo-900/40', aspect: 'h-72' },
  { id: 6, title: 'Diskusi Kelompok KWN', category: 'Persiapan', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>', color: 'bg-purple-900/40', aspect: 'h-48' },
  { id: 7, title: 'Pembuatan Media Edukasi', category: 'Persiapan', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m12 19-7-7 7-7 7 7-7 7z"/><path d="m19 12-7 7-7-7"/></svg>', color: 'bg-pink-900/40', aspect: 'h-56' },
  { id: 8, title: 'Bank Sampah Kunjungan', category: 'Aksi Lapangan', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>', color: 'bg-orange-900/40', aspect: 'h-64' },
  { id: 9, title: 'Presentasi Program KWN', category: 'Sosialisasi', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>', color: 'bg-yellow-900/40', aspect: 'h-48' },
];

const categories = ['Semua', 'Sosialisasi', 'Workshop', 'Aksi Lapangan', 'Survei', 'Persiapan'];
---

<BaseLayout title="Galeri" description="Dokumentasi kegiatan program KWN Galatea — sosialisasi, workshop, dan aksi lapangan.">

  <!-- Hero -->
  <section class="pt-32 pb-12 relative overflow-hidden">
    <!-- removed glowing background -->
    <div class="section-container relative">
      <div class="max-w-2xl" data-aos>
        <span class="section-badge">Dokumentasi</span>
        <h1 class="section-heading text-white mt-6">
          Galeri <span class="text-primary-500">Kegiatan</span>
        </h1>
        <p class="text-gray-400 text-lg mt-4 leading-relaxed">
          Dokumentasi visual perjalanan program KWN Galatea — dari perencanaan hingga aksi nyata di lapangan.
          Foto kegiatan akan diperbarui secara berkala.
        </p>
      </div>

      <!-- Filter -->
      <div class="flex flex-wrap gap-3 mt-8">
        {categories.map((cat) => (
          <button
            class="gallery-filter-btn px-5 py-2 rounded-full text-sm font-medium transition-all duration-200"
            data-filter={cat === 'Semua' ? 'all' : cat}
          >
            {cat}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Gallery Masonry -->
  <section class="py-8 pb-24">
    <div class="section-container">
      <div class="gallery-grid" id="gallery-grid">
        {galleryItems.map((item, i) => (
          <div
            class="gallery-item gallery-card group cursor-pointer"
            data-category={item.category}
            data-aos
            data-aos-delay={String((i % 3) * 100)}
          >
            <!-- Placeholder card -->
            <div
              class={`${item.color} ${item.aspect} rounded-lg border border-white/10 flex flex-col items-center justify-center relative overflow-hidden group-hover:border-white/20 transition-all duration-300`}
            >
              <div class="w-12 h-12 mb-3 text-white/50 group-hover:text-white group-hover:scale-110 transition-all duration-500" set:html={item.icon}></div>
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-4">
                <div>
                  <p class="text-white font-semibold text-sm">{item.title}</p>
                  <span class="text-white/60 text-xs">{item.category}</span>
                </div>
              </div>
              <!-- Placeholder tag -->
              <span class="absolute top-3 right-3 bg-black/40 backdrop-blur-sm text-white/70 text-xs px-2 py-1 rounded-full flex items-center">
                <svg class="w-3 h-3 mr-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg> Segera
              </span>
            </div>
            <div class="mt-3 px-1 pb-2">
              <p class="text-gray-300 text-sm font-medium">{item.title}</p>
              <span class="text-gray-600 text-xs">{item.category}</span>
            </div>
          </div>
        ))}
      </div>

      <!-- Upload notice -->
      <div class="card-glass p-8 mt-8 text-center" data-aos>
        <div class="w-10 h-10 mx-auto mb-4 text-primary-400"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg></div>
        <h3 class="text-white font-semibold text-xl mb-2">Dokumentasi Sedang Dikumpulkan</h3>
        <p class="text-gray-400 text-sm max-w-md mx-auto">
          Foto dan video kegiatan akan ditambahkan setelah setiap sesi program berlangsung.
        </p>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .gallery-filter-btn {
    background: rgba(255,255,255,0.05);
    color: #9ca3af;
    border: 1px solid rgba(255,255,255,0.1);
  }
  .gallery-filter-btn.active, .gallery-filter-btn:hover {
    background: rgba(45, 106, 79, 0.4);
    color: #86efac;
    border-color: rgba(82, 183, 136, 0.4);
  }
  .gallery-card.hidden-filter {
    display: none;
  }
</style>

<script>
  const btns = document.querySelectorAll('.gallery-filter-btn');
  const cards = document.querySelectorAll('.gallery-card');
  btns[0]?.classList.add('active');

  btns.forEach((btn) => {
    btn.addEventListener('click', () => {
      btns.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      const filter = (btn as HTMLElement).dataset.filter;
      cards.forEach((card) => {
        const cat = (card as HTMLElement).dataset.category;
        card.classList.toggle('hidden-filter', filter !== 'all' && cat !== filter);
      });
    });
  });
</script>
