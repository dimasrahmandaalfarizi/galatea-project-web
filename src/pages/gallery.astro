---
import BaseLayout from '../layouts/BaseLayout.astro';

const galleryItems = [
  { id: 1, title: 'Sosialisasi Pemilahan Sampah', category: 'Sosialisasi', emoji: '📢', color: 'bg-green-900/40', aspect: 'h-48' },
  { id: 2, title: 'Workshop Komposting', category: 'Workshop', emoji: '🌱', color: 'bg-emerald-900/40', aspect: 'h-64' },
  { id: 3, title: 'Pemasangan Poster di RW', category: 'Aksi Lapangan', emoji: '📌', color: 'bg-teal-900/40', aspect: 'h-56' },
  { id: 4, title: 'Survei Kuesioner Warga', category: 'Survei', emoji: '📋', color: 'bg-blue-900/40', aspect: 'h-48' },
  { id: 5, title: 'Pemilahan Sampah Bersama', category: 'Aksi Lapangan', emoji: '♻️', color: 'bg-indigo-900/40', aspect: 'h-72' },
  { id: 6, title: 'Diskusi Kelompok KWN', category: 'Persiapan', emoji: '💬', color: 'bg-purple-900/40', aspect: 'h-48' },
  { id: 7, title: 'Pembuatan Media Edukasi', category: 'Persiapan', emoji: '🎨', color: 'bg-pink-900/40', aspect: 'h-56' },
  { id: 8, title: 'Bank Sampah Kunjungan', category: 'Aksi Lapangan', emoji: '🏦', color: 'bg-orange-900/40', aspect: 'h-64' },
  { id: 9, title: 'Presentasi Program KWN', category: 'Sosialisasi', emoji: '🎤', color: 'bg-yellow-900/40', aspect: 'h-48' },
];

const categories = ['Semua', 'Sosialisasi', 'Workshop', 'Aksi Lapangan', 'Survei', 'Persiapan'];
---

<BaseLayout title="Galeri" description="Dokumentasi kegiatan program KWN EcoWijaya — sosialisasi, workshop, dan aksi lapangan.">

  <!-- Hero -->
  <section class="pt-32 pb-12 relative overflow-hidden">
    <div class="absolute bottom-0 left-0 w-80 h-80 bg-orange-600/5 rounded-full blur-3xl"></div>
    <div class="section-container relative">
      <div class="max-w-2xl" data-aos>
        <span class="section-badge">Dokumentasi</span>
        <h1 class="section-heading text-white mt-6">
          Galeri <span class="gradient-text italic">Kegiatan</span>
        </h1>
        <p class="text-gray-400 text-lg mt-4 leading-relaxed">
          Dokumentasi visual perjalanan program KWN EcoWijaya — dari perencanaan hingga aksi nyata di lapangan.
          Foto kegiatan akan diperbarui secara berkala.
        </p>
      </div>

      <!-- Filter -->
      <div class="flex flex-wrap gap-3 mt-8">
        {categories.map((cat) => (
          <button
            class="gallery-filter-btn px-5 py-2 rounded-full text-sm font-medium transition-all duration-200"
            data-filter={cat === 'Semua' ? 'all' : cat}
          >
            {cat}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Gallery Masonry -->
  <section class="py-8 pb-24">
    <div class="section-container">
      <div class="gallery-grid" id="gallery-grid">
        {galleryItems.map((item, i) => (
          <div
            class="gallery-item gallery-card group cursor-pointer"
            data-category={item.category}
            data-aos
            data-aos-delay={String((i % 3) * 100)}
          >
            <!-- Placeholder card -->
            <div
              class={`${item.color} ${item.aspect} rounded-2xl border border-white/10 flex flex-col items-center justify-center relative overflow-hidden group-hover:border-white/20 transition-all duration-300`}
            >
              <div class="text-5xl mb-3 group-hover:scale-110 transition-transform duration-500">{item.emoji}</div>
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-4">
                <div>
                  <p class="text-white font-semibold text-sm">{item.title}</p>
                  <span class="text-white/60 text-xs">{item.category}</span>
                </div>
              </div>
              <!-- Placeholder tag -->
              <span class="absolute top-3 right-3 bg-black/40 backdrop-blur-sm text-white/70 text-xs px-2 py-1 rounded-full">
                📸 Segera
              </span>
            </div>
            <div class="mt-3 px-1 pb-2">
              <p class="text-gray-300 text-sm font-medium">{item.title}</p>
              <span class="text-gray-600 text-xs">{item.category}</span>
            </div>
          </div>
        ))}
      </div>

      <!-- Upload notice -->
      <div class="card-glass p-8 mt-8 text-center" data-aos>
        <div class="text-4xl mb-4">📸</div>
        <h3 class="text-white font-semibold text-xl mb-2">Dokumentasi Sedang Dikumpulkan</h3>
        <p class="text-gray-400 text-sm max-w-md mx-auto">
          Foto dan video kegiatan akan ditambahkan setelah setiap sesi program berlangsung.
        </p>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .gallery-filter-btn {
    background: rgba(255,255,255,0.05);
    color: #9ca3af;
    border: 1px solid rgba(255,255,255,0.1);
  }
  .gallery-filter-btn.active, .gallery-filter-btn:hover {
    background: rgba(45, 106, 79, 0.4);
    color: #86efac;
    border-color: rgba(82, 183, 136, 0.4);
  }
  .gallery-card.hidden-filter {
    display: none;
  }
</style>

<script>
  const btns = document.querySelectorAll('.gallery-filter-btn');
  const cards = document.querySelectorAll('.gallery-card');
  btns[0]?.classList.add('active');

  btns.forEach((btn) => {
    btn.addEventListener('click', () => {
      btns.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      const filter = (btn as HTMLElement).dataset.filter;
      cards.forEach((card) => {
        const cat = (card as HTMLElement).dataset.category;
        card.classList.toggle('hidden-filter', filter !== 'all' && cat !== filter);
      });
    });
  });
</script>
