---
import BaseLayout from '../layouts/BaseLayout.astro';
import Parser from 'rss-parser';

const infographics = [
  {
    id: 'waste-types',
    title: 'Jenis-Jenis Sampah',
    subtitle: 'Kenali perbedaan sampah organik, anorganik, dan B3',
    items: [
      { label: 'Organik', pct: 60, color: '#52B788', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>', example: 'Sisa makanan, daun' },
      { label: 'Plastik', pct: 15, color: '#60a5fa', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="M15.2 3a2 2 0 0 1 1.4.6l3.8 3.8a2 2 0 0 1 .6 1.4V19a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h10.2Z"/><path d="M17 21v-7a2 2 0 0 0-2-2H9a2 2 0 0 0-2 2v7"/></svg>', example: 'Botol, kantong plastik' },
      { label: 'Kertas', pct: 12, color: '#fbbf24', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>', example: 'Koran, karton' },
      { label: 'Logam', pct: 8, color: '#f87171', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="m21 16-5.16-5.16a2 2 0 0 0-2.83 0l-5.17 5.17a2 2 0 0 0 0 2.83l5.17 5.17a2 2 0 0 0 2.83 0L21 18.84V16Z"/><path d="m2 16 5.16-5.16a2 2 0 0 1 2.83 0l5.17 5.17a2 2 0 0 1 0 2.83l-5.17 5.17a2 2 0 0 1-2.83 0L2 18.84V16Z"/></svg>', example: 'Kaleng, besi' },
      { label: 'Lainnya', pct: 5, color: '#a78bfa', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>', example: 'Karet, tekstil' },
    ],
  },
];

const wasteSteps = [
  { num: '1', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>', title: 'Pilah di Rumah', desc: 'Sediakan 3 tempat sampah: organik, anorganik, dan residu.', color: 'border-green-700/40 bg-green-900/20' },
  { num: '2', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>', title: 'Gunakan Wadah Tepat', desc: 'Pastikan wadah tertutup rapat untuk mencegah bau dan penyakit.', color: 'border-blue-700/40 bg-blue-900/20' },
  { num: '3', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>', title: 'Kelola Berkala', desc: 'Olah organik jadi kompos, setor anorganik ke bank sampah.', color: 'border-yellow-700/40 bg-yellow-900/20' },
  { num: '4', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M21 12a9 9 0 1 0-9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"/><path d="M21 21v-5h-5"/></svg>', title: 'Daur Ulang', desc: 'Bawa anorganik bersih ke pengepul atau fasilitas daur ulang.', color: 'border-purple-700/40 bg-purple-900/20' },
];

const impacts = [
  { icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="M2 12h4l2-8 5 16 3-8h6"/></svg>', title: 'Pencemaran Air', pct: 78, color: '#60a5fa', desc: 'Sampah yang tidak terkelola mencemari sungai dan laut' },
  { icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="M17.5 19c2.5 0 4.5-2 4.5-4.5a4.5 4.5 0 0 0-8.5-1.5 4 4 0 0 0-7-1.5 5 5 0 0 0-1 9.5h12Z"/></svg>', title: 'Polusi Udara', pct: 65, color: '#f87171', desc: 'Pembakaran sampah menghasilkan gas berbahaya' },
  { icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><circle cx="12" cy="12" r="10"/><path d="M16 12A4 4 0 0 0 8 12"/></svg>', title: 'Dampak Biota Laut', pct: 83, color: '#34d399', desc: 'Sampah plastik mengancam kehidupan laut' },
  { icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><path d="M9 22V12h6v10"/></svg>', title: 'Risiko Kesehatan', pct: 70, color: '#fbbf24', desc: 'Sampah liar menjadi sarang penyakit' },
];

let newsItems = [];
try {
  const parser = new Parser({
    headers: {
      'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64)'
    }
  });
  
  const decodeHtml = (text) => {
    return text.replace(/&#(\d+);/g, (match, dec) => String.fromCharCode(dec))
               .replace(/&amp;/g, '&')
               .replace(/&quot;/g, '"')
               .replace(/&lt;/g, '<')
               .replace(/&gt;/g, '>');
  };

  const feed = await parser.parseURL('https://www.mongabay.co.id/feed/');
  if (feed && feed.items) {
    newsItems = feed.items.slice(0, 6).map(item => {
      let thumbnail = null;
      if (item.enclosure && item.enclosure.url) {
        thumbnail = item.enclosure.url;
      } else {
        const imgMatch = (item['content:encoded'] || item.content || '').match(/<img[^>]+src="([^">]+)"/);
        if (imgMatch) thumbnail = imgMatch[1];
      }
      return {
        title: decodeHtml(item.title),
        link: item.link,
        pubDate: new Date(item.pubDate).toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' }),
        thumbnail: thumbnail,
        source: 'Mongabay Indonesia'
      };
    });
  }
} catch (e) {
  console.error("Gagal mengambil berita:", e);
}
---

<BaseLayout title="Data & Berita" description="Infografis edukasi pemilahan sampah dan berita nasional terbaru mengenai lingkungan.">

  <!-- ═══════════════════════════════════ HERO ═══════════════════════════════════ -->
  <section class="pt-40 pb-24 relative overflow-hidden bg-[#0a110d] border-b border-white/5">
    <!-- Abstract Background Elements -->
    <div class="absolute inset-0 bg-[url('https://grainy-gradients.vercel.app/noise.svg')] opacity-20 mix-blend-overlay"></div>
    <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.03)_1px,transparent_1px)] bg-[size:40px_40px] [mask-image:radial-gradient(ellipse_60%_60%_at_50%_50%,#000_20%,transparent_100%)]"></div>

    <div class="section-container relative z-10 text-center">
      <div class="max-w-4xl mx-auto flex flex-col items-center">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-primary-500/30 bg-primary-900/30 backdrop-blur-md mb-8 hero-item opacity-0">
          <span class="w-2 h-2 rounded-full bg-primary-400 animate-pulse"></span>
          <span class="text-xs font-mono text-primary-300 uppercase tracking-widest">Live Data Center</span>
        </div>
        
        <h1 class="font-bold text-6xl md:text-8xl tracking-tighter text-white hero-item opacity-0 leading-[1.1] pb-2">
          Pusat <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-600">Data</span>
        </h1>
        
        <p class="text-gray-400 text-lg md:text-xl mt-6 max-w-2xl leading-relaxed font-light hero-item opacity-0">
          Visualisasi nyata mengenai komposisi sampah, serta sajian berita nasional dan lingkungan secara real-time dari portal terpercaya.
        </p>
      </div>
    </div>
    
    <!-- Bottom Fade -->
    <div class="absolute bottom-0 left-0 w-full h-24 bg-gradient-to-t from-[#0a110d] to-transparent"></div>
  </section>

  <!-- ═══════════════════════════════════ KPI SCORECARDS ═══════════════════════════════════ -->
  <section class="py-12 bg-[#0a110d] border-b border-white/5 relative overflow-hidden">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-4xl h-64 bg-primary-900/20 blur-[120px] rounded-full pointer-events-none"></div>
    <div class="section-container relative z-10">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        
        <!-- KPI 1 -->
        <div class="card-glass p-8 rounded-2xl border border-primary-500/30 shadow-[0_0_30px_rgba(45,106,79,0.15)] relative group hover:border-primary-400/60 transition-colors duration-500 scroll-fade-up opacity-0">
          <div class="absolute top-0 right-0 p-6 opacity-10 group-hover:opacity-20 transition-opacity">
             <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
          </div>
          <p class="text-primary-300 text-sm font-mono uppercase tracking-wider mb-2">Timbunan Nasional (2023)</p>
          <div class="flex items-end gap-2">
            <h3 class="text-5xl md:text-6xl font-bold text-white tracking-tight"><span class="motion-number" data-target="35.8">0</span></h3>
            <span class="text-gray-400 pb-1 md:pb-2">Juta Ton</span>
          </div>
          <p class="text-xs text-gray-500 mt-4 flex items-center gap-1">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#52B788" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
            <span class="text-green-400">+2.4%</span> dari tahun sebelumnya
          </p>
        </div>

        <!-- KPI 2 -->
        <div class="card-glass p-8 rounded-2xl border border-white/5 relative group hover:border-white/20 transition-colors duration-500 scroll-fade-up opacity-0" style="transition-delay: 100ms">
          <p class="text-gray-400 text-sm font-mono uppercase tracking-wider mb-2">Sampah Terkelola</p>
          <div class="flex items-end gap-2">
            <h3 class="text-5xl md:text-6xl font-bold text-white tracking-tight"><span class="motion-number" data-target="66.02">0</span></h3>
            <span class="text-gray-400 pb-1 md:pb-2">%</span>
          </div>
          <div class="w-full h-1.5 bg-white/10 rounded-full mt-6 overflow-hidden">
            <div class="h-full bg-primary-500 rounded-full motion-bar origin-left" data-target="66.02" style="transform: scaleX(0);"></div>
          </div>
        </div>

        <!-- KPI 3 -->
        <div class="card-glass p-8 rounded-2xl border border-white/5 relative group hover:border-red-500/30 transition-colors duration-500 scroll-fade-up opacity-0" style="transition-delay: 200ms">
          <p class="text-gray-400 text-sm font-mono uppercase tracking-wider mb-2">Belum Terkelola</p>
          <div class="flex items-end gap-2">
            <h3 class="text-5xl md:text-6xl font-bold text-white tracking-tight"><span class="motion-number" data-target="33.98">0</span></h3>
            <span class="text-gray-400 pb-1 md:pb-2">%</span>
          </div>
          <div class="w-full h-1.5 bg-white/10 rounded-full mt-6 overflow-hidden">
            <div class="h-full bg-red-500 rounded-full motion-bar origin-left" data-target="33.98" style="transform: scaleX(0);"></div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════ BERITA TERKINI (API) ═══════════════════════════════════ -->
  <section class="py-24 bg-[#0a110d] border-b border-white/5">
    <div class="section-container">
      <div class="flex flex-col md:flex-row justify-between items-end mb-16 scroll-fade-up opacity-0">
        <div>
          <h2 class="text-white font-bold tracking-tight text-4xl md:text-5xl mb-4">Berita <span class="text-primary-500">Terkini</span></h2>
          <p class="text-gray-400 font-light">Kabar terbaru perlindungan lingkungan ditarik langsung via API (Mongabay Indonesia).</p>
        </div>
        <div class="mt-6 md:mt-0">
          <span class="inline-flex items-center gap-2 bg-primary-900/30 border border-primary-500/30 text-primary-400 text-xs px-3 py-1 rounded-md">
            <span class="w-2 h-2 rounded-full bg-primary-500 animate-pulse"></span> Live Update
          </span>
        </div>
      </div>

      {newsItems.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 fact-container">
          {newsItems.map((news) => (
            <a href={news.link} target="_blank" rel="noopener noreferrer" class="fact-item opacity-0 group flex flex-col rounded-2xl border border-white/10 bg-[#0f1a14]/80 backdrop-blur-md hover:bg-[#132a1f] hover:border-primary-500/50 hover:shadow-[0_0_30px_rgba(45,106,79,0.3)] transition-all duration-500 overflow-hidden relative">
              <div class="absolute inset-0 bg-gradient-to-t from-[#0f1a14] via-transparent to-transparent z-10 pointer-events-none"></div>
              {news.thumbnail && (
                <div class="w-full h-52 overflow-hidden bg-[#1a1a1a] relative">
                  <img src={news.thumbnail} alt={news.title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700 opacity-80 group-hover:opacity-100" loading="lazy" />
                  <div class="absolute top-4 left-4 z-20">
                    <span class="bg-primary-600/90 backdrop-blur text-white text-[10px] uppercase font-bold tracking-wider px-3 py-1 rounded-full shadow-lg">Terkini</span>
                  </div>
                </div>
              )}
              <div class="p-8 flex flex-col flex-1 relative z-20">
                <div class="text-xs text-primary-400 mb-3 font-medium tracking-wide flex items-center gap-2">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                  {news.pubDate}
                </div>
                <h3 class="text-white font-bold text-xl leading-snug mb-6 group-hover:text-primary-300 transition-colors line-clamp-3" title={news.title}>{news.title}</h3>
                <div class="mt-auto flex items-center justify-between text-sm text-gray-400 font-light border-t border-white/10 pt-4 group-hover:border-primary-500/30 transition-colors">
                  <span class="flex items-center gap-2">
                    <div class="w-5 h-5 rounded-full bg-primary-900/50 flex items-center justify-center text-primary-400 text-[10px] font-bold">M</div>
                    {news.source}
                  </span>
                  <div class="w-8 h-8 rounded-full bg-white/5 flex items-center justify-center group-hover:bg-primary-500 group-hover:text-white transition-colors">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform">
                      <path d="M5 12h14M12 5l7 7-7 7"/>
                    </svg>
                  </div>
                </div>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="p-12 text-center rounded-lg border border-white/10 bg-[#111]">
          <p class="text-gray-400">Sedang mengambil berita atau API tidak tersedia saat ini.</p>
        </div>
      )}
    </div>
  </section>

  <!-- ═══════════════════════════════════ CHART KOMPOSISI SAMPAH (API) ═══════════════════════════════════ -->
  <section class="py-24 bg-[#0a110d] relative border-b border-white/5">
    <div class="section-container relative z-10">
      <div class="mb-12 text-center scroll-fade-up opacity-0">
        <h2 class="text-white font-bold tracking-tight text-4xl md:text-5xl mb-4">Komposisi <span class="text-primary-500">Sampah</span></h2>
        <p class="text-gray-400 font-light max-w-2xl mx-auto">Data real-time berdasarkan Sistem Informasi Pengelolaan Sampah Nasional (SIPSN) Kementerian LHK RI Tahun 2023.</p>
        <div class="mt-4 flex justify-center">
          <a href="https://sipsn.menlhk.go.id/sipsn/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-primary-900/30 border border-primary-500/30 text-primary-400 text-xs px-4 py-2 rounded-full hover:bg-primary-900/50 transition-colors">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            Sumber Bukti Data (SIPSN)
          </a>
        </div>
      </div>

      <div class="max-w-5xl mx-auto rounded-xl border border-white/10 bg-[#111] p-8 md:p-12 scroll-fade-up opacity-0" id="composition-container">
        <!-- Loading state -->
        <div id="comp-loading" class="flex flex-col items-center justify-center py-12">
          <div class="w-8 h-8 border-4 border-primary-500/30 border-t-primary-500 rounded-full animate-spin mb-4"></div>
          <p class="text-gray-400 text-sm">Mengambil data komposisi sampah dari API SIPSN...</p>
        </div>

        <!-- Chart Content (hidden by default) -->
        <div id="comp-content" class="hidden flex-col items-center justify-center">
          <!-- Donut Chart -->
          <div class="relative w-full max-w-[400px] aspect-square">
            <canvas id="chartjs-sipsn"></canvas>
            <div class="absolute inset-0 flex flex-col items-center justify-center pointer-events-none pb-4">
              <span class="text-white text-3xl md:text-4xl font-bold" id="comp-total-val">0</span>
              <span class="text-gray-500 text-xs uppercase tracking-wider">Juta Ton</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════ CHART SAMPAH REGIONAL (ASEAN) ═══════════════════════════════════ -->
  <section class="py-24 bg-[#0a110d] relative border-b border-white/5">
    <div class="section-container relative z-10">
      <div class="mb-12 text-center scroll-fade-up opacity-0">
        <span class="section-badge mb-4">Skala Global</span>
        <h2 class="text-white font-bold tracking-tight text-4xl md:text-5xl mb-4">Perbandingan <span class="text-primary-500">Asia Tenggara</span></h2>
        <p class="text-gray-400 font-light max-w-2xl mx-auto">Volume produksi sampah tahunan di berbagai negara Asia Tenggara berdasarkan data estimasi global.</p>
      </div>

      <div class="max-w-5xl mx-auto rounded-xl border border-white/10 bg-[#111] p-8 md:p-12 scroll-fade-up opacity-0">
        <!-- Loading state -->
        <div id="asean-loading" class="flex flex-col items-center justify-center py-12">
          <div class="w-8 h-8 border-4 border-primary-500/30 border-t-primary-500 rounded-full animate-spin mb-4"></div>
          <p class="text-gray-400 text-sm">Mengambil data regional...</p>
        </div>

        <!-- Chart Content (hidden by default) -->
        <div id="asean-content" class="hidden flex flex-col items-center w-full">
          <!-- Canvas for Bar Chart -->
          <div class="relative w-full h-[400px]">
            <canvas id="chartjs-asean"></canvas>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════ DAMPAK & LANGKAH ═══════════════════════════════════ -->
  <section class="py-24 bg-[#0f1a14]">
    <div class="section-container">
      
      <!-- Dampak Lingkungan -->
      <div class="mb-32">
        <div class="text-center mb-16 scroll-fade-up opacity-0">
          <h2 class="text-white font-bold tracking-tight text-4xl md:text-5xl mb-4">Dampak <span class="text-red-400">Kegagalan</span></h2>
          <p class="text-gray-400 font-light max-w-2xl mx-auto">Efek domino yang dihasilkan ketika manajemen limbah gagal dijalankan dengan benar.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 impact-container">
          {impacts.map((imp) => (
            <div class="impact-item opacity-0 p-6 md:p-8 rounded-lg border border-white/10 bg-[#111] flex items-center gap-6 group hover:border-white/20 transition-colors duration-500">
              <div class="w-14 h-14 rounded-md flex items-center justify-center bg-white/5 shrink-0 group-hover:scale-105 transition-all duration-500" style={`color: ${imp.color}`}>
                <div class="w-7 h-7" set:html={imp.icon}></div>
              </div>
              <div class="flex-1">
                <div class="flex justify-between items-center mb-2">
                  <h3 class="text-white text-lg font-bold">{imp.title}</h3>
                  <span class="text-xl font-bold" style={`color: ${imp.color}`}>
                    <span class="motion-number" data-target={imp.pct}>0</span>%
                  </span>
                </div>
                <div class="h-1 w-full bg-white/5 rounded-full overflow-hidden mt-3">
                  <div class="h-full rounded-full motion-bar origin-left" data-target={imp.pct} style={`background-color: ${imp.color}; transform: scaleX(0);`}></div>
                </div>
                <p class="text-gray-400 text-sm mt-3 font-light leading-relaxed">{imp.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- 4 Langkah Pemilahan -->
      <div>
        <div class="text-center mb-16 scroll-fade-up opacity-0">
          <span class="section-badge mb-4">Panduan Ops</span>
          <h2 class="text-white font-bold tracking-tight text-4xl md:text-5xl mb-4">Prosedur <span class="text-primary-500">Standar</span></h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 step-container">
          {wasteSteps.map((step, i) => (
            <div class={`step-item opacity-0 relative rounded-lg border border-white/10 bg-[#111] p-6 group hover:border-white/20 transition-all duration-500`}>
              <div class="w-10 h-10 mb-6 text-primary-400 group-hover:scale-105 transition-transform duration-500 origin-bottom-left" set:html={step.icon}></div>
              <h3 class="text-white font-bold text-lg mb-2 tracking-tight">{step.num}. {step.title}</h3>
              <p class="text-gray-400 text-sm leading-relaxed font-light">{step.desc}</p>
            </div>
          ))}
        </div>
      </div>

    </div>
  </section>

</BaseLayout>

<script>
  // @ts-nocheck
  import { animate, inView, stagger } from "motion";

  // 1. Hero Animations
  const heroItems = Array.from(document.querySelectorAll('.hero-item'));
  if (heroItems.length) {
    animate(
      heroItems,
      { opacity: 1, y: [-20, 0] },
      { 
        duration: 0.8, 
        delay: stagger(0.1, { startDelay: 0.1 }),
        easing: [0.17, 0.55, 0.55, 1]
      }
    );
  }

  // 2. Bento Grid Animations
  inView('.bento-container', (element) => {
    const items = Array.from(element.querySelectorAll('.bento-item'));
    if (items.length) {
      animate(
        items,
        { opacity: 1, scale: [0.95, 1] },
        { 
          duration: 0.6, 
          delay: stagger(0.05),
          easing: [0.17, 0.55, 0.55, 1] 
        }
      );
    }
  });

  // 3. Impact Cards & Progress Bars
  inView('.impact-container', (element) => {
    const items = Array.from(element.querySelectorAll('.impact-item'));
    if (items.length) {
      animate(
        items,
        { opacity: 1, y: [20, 0] },
        { duration: 0.6, delay: stagger(0.1), easing: "ease-out" }
      );
    }

    const bars = Array.from(element.querySelectorAll('.motion-bar'));
    bars.forEach((bar, index) => {
      const el = bar as HTMLElement;
      const pct = parseFloat(el.dataset.target || '0');
      animate(
        el,
        { transform: `scaleX(${pct / 100})` },
        { duration: 1.2, delay: 0.4 + (index * 0.1), easing: [0.17, 0.55, 0.55, 1] }
      );
    });
  });

  // 4. Step Cards
  inView('.step-container', (element) => {
    const items = Array.from(element.querySelectorAll('.step-item'));
    if (items.length) {
      animate(
        items,
        { opacity: 1, y: [20, 0] },
        { duration: 0.6, delay: stagger(0.1), easing: [0.17, 0.55, 0.55, 1] }
      );
    }
  });

  // 5. Fact/News Cards
  inView('.fact-container', (element) => {
    const items = Array.from(element.querySelectorAll('.fact-item'));
    if (items.length) {
      animate(
        items,
        { opacity: 1, y: [20, 0] },
        { duration: 0.6, delay: stagger(0.1), easing: "ease-out" }
      );
    }
  });

  // 6. Generic Scroll Fade Up
  inView('.scroll-fade-up', (element) => {
    animate(element, { opacity: 1, y: [-20, 0] }, { duration: 0.6, easing: "ease-out" });
  });

  // 7. Motion Numbers
  setTimeout(() => {
    document.querySelectorAll('.motion-number').forEach(el => {
      inView(el, (element) => {
        const target = parseFloat((element as HTMLElement).dataset.target || '0');
        animate(0, target, {
          duration: 1.5,
          delay: 0.2,
          easing: "ease-out",
          onUpdate: (latest) => {
            element.textContent = Math.round(latest).toString();
          }
        });
      });
    });
  }, 100);

  // 8. Fetch Waste Composition API and Draw Donut Chart
  import Chart from 'chart.js/auto';
  
  const compContainer = document.getElementById('composition-container');
  if (compContainer) {
    const loading = document.getElementById('comp-loading');
    const content = document.getElementById('comp-content');
    const totalVal = document.getElementById('comp-total-val');
    const canvas = document.getElementById('chartjs-sipsn') as HTMLCanvasElement;

    // Simulate network delay for API fetch to show loading state clearly
    setTimeout(async () => {
      try {
        // Fetch real SIPSN data from our local API mirror
        const res = await fetch('/api/sipsn-2023.json');
        const data = await res.json();
        
        loading?.classList.add('hidden');
        content?.classList.remove('hidden');
        content?.classList.add('flex');

        if (totalVal) {
          animate(0, data.total_waste_tons / 1000000, {
            duration: 1.5,
            easing: "ease-out",
            onUpdate: (latest) => {
              totalVal.textContent = latest.toFixed(1);
            }
          });
        }

        if (canvas && data.composition) {
          new Chart(canvas, {
            type: 'doughnut',
            data: {
              labels: data.composition.map((d: any) => d.category),
              datasets: [{
                data: data.composition.map((d: any) => d.percentage),
                backgroundColor: data.composition.map((d: any) => d.color),
                borderWidth: 0,
                hoverOffset: 10
              }]
            },
            options: {
              responsive: true,
              cutout: '70%',
              plugins: {
                legend: {
                  position: 'bottom',
                  labels: {
                    color: '#9ca3af',
                    font: { family: 'Inter', size: 12 },
                    padding: 20,
                    usePointStyle: true,
                  }
                },
                tooltip: {
                  backgroundColor: 'rgba(15, 26, 20, 0.9)',
                  titleColor: '#fff',
                  bodyColor: '#fff',
                  borderColor: 'rgba(82, 183, 136, 0.3)',
                  borderWidth: 1,
                  padding: 12,
                  boxPadding: 6,
                  callbacks: {
                    label: function(context) {
                      return ` ${context.label}: ${context.raw}%`;
                    }
                  }
                }
              },
              animation: {
                animateScale: true,
                animateRotate: true,
                duration: 2000,
                easing: 'easeOutQuart'
              }
            }
          });
        }
      } catch (err) {
        if (loading) {
          loading.innerHTML = '<p class="text-red-400 text-sm font-medium">Gagal mengambil data dari API SIPSN.</p>';
        }
      }

      // Fetch ASEAN Waste Data
      try {
        const aseanLoading = document.getElementById('asean-loading');
        const aseanContent = document.getElementById('asean-content');
        const aseanCanvas = document.getElementById('chartjs-asean') as HTMLCanvasElement;

        const aseanRes = await fetch('/api/asean-waste.json');
        const aseanData = await aseanRes.json();
        
        if (aseanLoading && aseanContent) {
          aseanLoading.classList.add('hidden');
          aseanContent.classList.remove('hidden');
          aseanContent.classList.add('flex');
        }

        if (aseanCanvas && aseanData.data) {
          new Chart(aseanCanvas, {
            type: 'bar',
            data: {
              labels: aseanData.data.map((d: any) => d.country),
              datasets: [{
                label: 'Juta Ton per Tahun',
                data: aseanData.data.map((d: any) => d.tons),
                backgroundColor: aseanData.data.map((d: any) => d.color),
                borderRadius: 6,
                borderSkipped: false,
                barPercentage: 0.6
              }]
            },
            options: {
              responsive: true,
              maintainAspectRatio: false,
              plugins: {
                legend: {
                  display: false // Hide default legend since x-axis is already labeled
                },
                tooltip: {
                  backgroundColor: 'rgba(15, 26, 20, 0.9)',
                  titleColor: '#fff',
                  bodyColor: '#52B788',
                  titleFont: { size: 14 },
                  padding: 12,
                  borderColor: 'rgba(255,255,255,0.1)',
                  borderWidth: 1,
                  callbacks: {
                    label: function(context) {
                      return ` ${context.raw} Juta Ton`;
                    }
                  }
                }
              },
              scales: {
                y: {
                  beginAtZero: true,
                  grid: {
                    color: 'rgba(255, 255, 255, 0.05)',
                  },
                  ticks: {
                    color: '#6b7280',
                    font: { family: 'Inter' }
                  }
                },
                x: {
                  grid: {
                    display: false
                  },
                  ticks: {
                    color: '#9ca3af',
                    font: { family: 'Inter', size: 11 }
                  }
                }
              },
              animation: {
                duration: 2000,
                easing: 'easeOutElastic'
              }
            }
          });
        }
      } catch (err) {
        console.error("Gagal memuat data ASEAN", err);
      }

    }, 800);
  }


</script>
