---
import BaseLayout from '../layouts/BaseLayout.astro';

const infographics = [
  {
    id: 'waste-types',
    title: 'Jenis-Jenis Sampah',
    subtitle: 'Kenali perbedaan sampah organik, anorganik, dan B3',
    items: [
      { label: 'Organik', pct: 60, color: '#52B788', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>', example: 'Sisa makanan, daun' },
      { label: 'Plastik', pct: 15, color: '#60a5fa', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="M15.2 3a2 2 0 0 1 1.4.6l3.8 3.8a2 2 0 0 1 .6 1.4V19a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h10.2Z"/><path d="M17 21v-7a2 2 0 0 0-2-2H9a2 2 0 0 0-2 2v7"/></svg>', example: 'Botol, kantong plastik' },
      { label: 'Kertas', pct: 12, color: '#fbbf24', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>', example: 'Koran, karton' },
      { label: 'Logam', pct: 8, color: '#f87171', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="m21 16-5.16-5.16a2 2 0 0 0-2.83 0l-5.17 5.17a2 2 0 0 0 0 2.83l5.17 5.17a2 2 0 0 0 2.83 0L21 18.84V16Z"/><path d="m2 16 5.16-5.16a2 2 0 0 1 2.83 0l5.17 5.17a2 2 0 0 1 0 2.83l-5.17 5.17a2 2 0 0 1-2.83 0L2 18.84V16Z"/></svg>', example: 'Kaleng, besi' },
      { label: 'Lainnya', pct: 5, color: '#a78bfa', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>', example: 'Karet, tekstil' },
    ],
  },
];

const wasteSteps = [
  { num: '1', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>', title: 'Pilah di Rumah', desc: 'Sediakan 3 tempat sampah: organik, anorganik, dan residu.', color: 'border-green-700/40 bg-green-900/20' },
  { num: '2', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>', title: 'Gunakan Wadah Tepat', desc: 'Pastikan wadah tertutup rapat untuk mencegah bau dan penyakit.', color: 'border-blue-700/40 bg-blue-900/20' },
  { num: '3', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>', title: 'Kelola Berkala', desc: 'Olah organik jadi kompos, setor anorganik ke bank sampah.', color: 'border-yellow-700/40 bg-yellow-900/20' },
  { num: '4', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M21 12a9 9 0 1 0-9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"/><path d="M21 21v-5h-5"/></svg>', title: 'Daur Ulang', desc: 'Bawa anorganik bersih ke pengepul atau fasilitas daur ulang.', color: 'border-purple-700/40 bg-purple-900/20' },
];

const impacts = [
  { icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="M2 12h4l2-8 5 16 3-8h6"/></svg>', title: 'Pencemaran Air', pct: 78, color: '#60a5fa', desc: 'Sampah yang tidak terkelola mencemari sungai dan laut' },
  { icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="M17.5 19c2.5 0 4.5-2 4.5-4.5a4.5 4.5 0 0 0-8.5-1.5 4 4 0 0 0-7-1.5 5 5 0 0 0-1 9.5h12Z"/></svg>', title: 'Polusi Udara', pct: 65, color: '#f87171', desc: 'Pembakaran sampah menghasilkan gas berbahaya' },
  { icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><circle cx="12" cy="12" r="10"/><path d="M16 12A4 4 0 0 0 8 12"/></svg>', title: 'Dampak Biota Laut', pct: 83, color: '#34d399', desc: 'Sampah plastik mengancam kehidupan laut' },
  { icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><path d="M9 22V12h6v10"/></svg>', title: 'Risiko Kesehatan', pct: 70, color: '#fbbf24', desc: 'Sampah liar menjadi sarang penyakit' },
];

let newsItems = [];
try {
  const res = await fetch('https://api.rss2json.com/v1/api.json?rss_url=https://www.cnnindonesia.com/nasional/rss');
  const data = await res.json();
  if (data && data.items) {
    newsItems = data.items.slice(0, 6);
  }
} catch (e) {
  console.error("Gagal mengambil berita:", e);
}
---

<BaseLayout title="Data & Berita" description="Infografis edukasi pemilahan sampah dan berita nasional terbaru mengenai lingkungan.">

  <!-- ═══════════════════════════════════ HERO ═══════════════════════════════════ -->
  <section class="pt-40 pb-20 relative bg-[#0f1a14] border-b border-white/5">
    <div class="section-container relative z-10 text-center">
      <div class="max-w-4xl mx-auto flex flex-col items-center">
        <span class="section-badge mb-6 hero-item opacity-0">Data & Analitik</span>
        <h1 class="font-bold text-6xl md:text-8xl tracking-tighter text-white hero-item opacity-0 leading-[0.95]">
          Pusat <span class="text-primary-500">Data</span>
        </h1>
        <p class="text-gray-300 text-lg md:text-xl mt-8 max-w-2xl leading-relaxed font-light hero-item opacity-0">
          Visualisasi nyata mengenai komposisi sampah, serta sajian berita nasional dan lingkungan secara real-time dari portal terpercaya.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════ BERITA TERKINI (API) ═══════════════════════════════════ -->
  <section class="py-24 bg-[#0a110d] border-b border-white/5">
    <div class="section-container">
      <div class="flex flex-col md:flex-row justify-between items-end mb-16 scroll-fade-up opacity-0">
        <div>
          <h2 class="text-white font-bold tracking-tight text-4xl md:text-5xl mb-4">Berita <span class="text-primary-500">Terkini</span></h2>
          <p class="text-gray-400 font-light">Berita nasional ditarik otomatis via API (CNN Indonesia RSS).</p>
        </div>
        <div class="mt-6 md:mt-0">
          <span class="inline-flex items-center gap-2 bg-primary-900/30 border border-primary-500/30 text-primary-400 text-xs px-3 py-1 rounded-md">
            <span class="w-2 h-2 rounded-full bg-primary-500 animate-pulse"></span> Live Update
          </span>
        </div>
      </div>

      {newsItems.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 fact-container">
          {newsItems.map((news) => (
            <a href={news.link} target="_blank" rel="noopener noreferrer" class="fact-item opacity-0 group flex flex-col rounded-lg border border-white/10 bg-[#111] hover:bg-white/5 transition-all duration-300 overflow-hidden">
              {news.thumbnail && (
                <div class="w-full h-48 overflow-hidden bg-[#1a1a1a]">
                  <img src={news.thumbnail} alt={news.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                </div>
              )}
              <div class="p-6 flex flex-col flex-1">
                <div class="text-xs text-primary-400 mb-3 font-semibold tracking-wide uppercase">{new Date(news.pubDate.replace(' ', 'T')).toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' })}</div>
                <h3 class="text-white font-bold text-lg leading-tight mb-4 group-hover:text-primary-400 transition-colors">{news.title}</h3>
                <div class="mt-auto pt-4 border-t border-white/10 flex items-center justify-between text-sm text-gray-500">
                  <span>CNN Indonesia</span>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform">
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                  </svg>
                </div>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="p-12 text-center rounded-lg border border-white/10 bg-[#111]">
          <p class="text-gray-400">Sedang mengambil berita atau API tidak tersedia saat ini.</p>
        </div>
      )}
    </div>
  </section>

  <!-- ═══════════════════════════════════ BENTO GRID (KOMPOSISI) ═══════════════════════════════════ -->
  <section class="py-24 bg-[#0a110d] relative border-b border-white/5">
    <div class="section-container relative z-10">
      <div class="mb-16 text-center scroll-fade-up opacity-0">
        <h2 class="text-white font-bold tracking-tight text-4xl md:text-5xl mb-4">Komposisi <span class="text-primary-500">Sampah</span></h2>
        <p class="text-gray-400 font-light">Data KLHK 2023. Total 67 juta ton sampah diproduksi per tahun di Indonesia.</p>
      </div>

      <!-- Bento Grid Layout -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 auto-rows-[180px] bento-container">
        {infographics[0].items.map((item, i) => {
          // Bento Span Logic
          const spanClass = 
            i === 0 ? "col-span-2 row-span-2 md:col-span-2 md:row-span-2" : // Organik
            i === 1 ? "col-span-2 row-span-1 md:col-span-2 md:row-span-1" : // Plastik
            i === 2 ? "col-span-1 row-span-1 md:col-span-1 md:row-span-1" : // Kertas
            i === 3 ? "col-span-1 row-span-1 md:col-span-1 md:row-span-1" : // Logam
            "col-span-2 row-span-1 md:col-span-2 md:row-span-1";            // Lainnya
            
          return (
            <div 
              class={`bento-item opacity-0 relative overflow-hidden rounded-lg p-6 md:p-8 flex flex-col justify-between group border border-white/10 bg-[#111] hover:bg-white/5 transition-colors duration-500 ${spanClass}`}
            >
              <div class="relative z-10 flex justify-between items-start">
                <div class="w-10 h-10 md:w-12 md:h-12 group-hover:scale-110 transition-transform duration-500 origin-top-left" style={`color: ${item.color}`} set:html={item.icon}></div>
                <div class="text-right">
                  <div class="text-4xl md:text-5xl font-bold tracking-tighter" style={`color: ${item.color}`}>
                    <span class="motion-number" data-target={item.pct}>0</span>%
                  </div>
                </div>
              </div>
              
              <div class="relative z-10 mt-auto">
                <h3 class="text-white text-xl md:text-2xl font-bold tracking-tight mb-1">{item.label}</h3>
                <p class="text-gray-400 text-sm font-light">{item.example}</p>
              </div>
            </div>
          )
        })}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════ DAMPAK & LANGKAH ═══════════════════════════════════ -->
  <section class="py-24 bg-[#0f1a14]">
    <div class="section-container">
      
      <!-- Dampak Lingkungan -->
      <div class="mb-32">
        <div class="text-center mb-16 scroll-fade-up opacity-0">
          <h2 class="text-white font-bold tracking-tight text-4xl md:text-5xl mb-4">Dampak <span class="text-red-400">Kegagalan</span></h2>
          <p class="text-gray-400 font-light max-w-2xl mx-auto">Efek domino yang dihasilkan ketika manajemen limbah gagal dijalankan dengan benar.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 impact-container">
          {impacts.map((imp) => (
            <div class="impact-item opacity-0 p-6 md:p-8 rounded-lg border border-white/10 bg-[#111] flex items-center gap-6 group hover:border-white/20 transition-colors duration-500">
              <div class="w-14 h-14 rounded-md flex items-center justify-center bg-white/5 shrink-0 group-hover:scale-105 transition-all duration-500" style={`color: ${imp.color}`}>
                <div class="w-7 h-7" set:html={imp.icon}></div>
              </div>
              <div class="flex-1">
                <div class="flex justify-between items-center mb-2">
                  <h3 class="text-white text-lg font-bold">{imp.title}</h3>
                  <span class="text-xl font-bold" style={`color: ${imp.color}`}>
                    <span class="motion-number" data-target={imp.pct}>0</span>%
                  </span>
                </div>
                <div class="h-1 w-full bg-white/5 rounded-full overflow-hidden mt-3">
                  <div class="h-full rounded-full motion-bar origin-left" data-target={imp.pct} style={`background-color: ${imp.color}; transform: scaleX(0);`}></div>
                </div>
                <p class="text-gray-400 text-sm mt-3 font-light leading-relaxed">{imp.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- 4 Langkah Pemilahan -->
      <div>
        <div class="text-center mb-16 scroll-fade-up opacity-0">
          <span class="section-badge mb-4">Panduan Ops</span>
          <h2 class="text-white font-bold tracking-tight text-4xl md:text-5xl mb-4">Prosedur <span class="text-primary-500">Standar</span></h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 step-container">
          {wasteSteps.map((step, i) => (
            <div class={`step-item opacity-0 relative rounded-lg border border-white/10 bg-[#111] p-6 group hover:border-white/20 transition-all duration-500`}>
              <div class="w-10 h-10 mb-6 text-primary-400 group-hover:scale-105 transition-transform duration-500 origin-bottom-left" set:html={step.icon}></div>
              <h3 class="text-white font-bold text-lg mb-2 tracking-tight">{step.num}. {step.title}</h3>
              <p class="text-gray-400 text-sm leading-relaxed font-light">{step.desc}</p>
            </div>
          ))}
        </div>
      </div>

    </div>
  </section>

</BaseLayout>

<script>
  import { animate, inView, stagger } from "motion";

  // 1. Hero Animations
  const heroItems = Array.from(document.querySelectorAll('.hero-item'));
  if (heroItems.length) {
    animate(
      heroItems,
      { opacity: 1, y: [-20, 0] },
      { 
        duration: 0.8, 
        delay: stagger(0.1, { startDelay: 0.1 }),
        easing: [0.17, 0.55, 0.55, 1]
      }
    );
  }

  // 2. Bento Grid Animations
  inView('.bento-container', (element) => {
    const items = Array.from(element.querySelectorAll('.bento-item'));
    if (items.length) {
      animate(
        items,
        { opacity: 1, scale: [0.95, 1] },
        { 
          duration: 0.6, 
          delay: stagger(0.05),
          easing: [0.17, 0.55, 0.55, 1] 
        }
      );
    }
  });

  // 3. Impact Cards & Progress Bars
  inView('.impact-container', (element) => {
    const items = Array.from(element.querySelectorAll('.impact-item'));
    if (items.length) {
      animate(
        items,
        { opacity: 1, y: [20, 0] },
        { duration: 0.6, delay: stagger(0.1), easing: "ease-out" }
      );
    }

    const bars = Array.from(element.querySelectorAll('.motion-bar'));
    bars.forEach((bar, index) => {
      const el = bar as HTMLElement;
      const pct = parseFloat(el.dataset.target || '0');
      animate(
        el,
        { transform: `scaleX(${pct / 100})` },
        { duration: 1.2, delay: 0.4 + (index * 0.1), easing: [0.17, 0.55, 0.55, 1] }
      );
    });
  });

  // 4. Step Cards
  inView('.step-container', (element) => {
    const items = Array.from(element.querySelectorAll('.step-item'));
    if (items.length) {
      animate(
        items,
        { opacity: 1, y: [20, 0] },
        { duration: 0.6, delay: stagger(0.1), easing: [0.17, 0.55, 0.55, 1] }
      );
    }
  });

  // 5. Fact/News Cards
  inView('.fact-container', (element) => {
    const items = Array.from(element.querySelectorAll('.fact-item'));
    if (items.length) {
      animate(
        items,
        { opacity: 1, y: [20, 0] },
        { duration: 0.6, delay: stagger(0.1), easing: "ease-out" }
      );
    }
  });

  // 6. Generic Scroll Fade Up
  inView('.scroll-fade-up', (element) => {
    animate(element, { opacity: 1, y: [-20, 0] }, { duration: 0.6, easing: "ease-out" });
  });

  // 7. Motion Numbers
  setTimeout(() => {
    document.querySelectorAll('.motion-number').forEach(el => {
      inView(el, (element) => {
        const target = parseFloat((element as HTMLElement).dataset.target || '0');
        animate(0, target, {
          duration: 1.5,
          delay: 0.2,
          easing: "ease-out",
          onUpdate: (latest) => {
            element.textContent = Math.round(latest).toString();
          }
        });
      });
    });
  }, 100);
</script>
