---
import BaseLayout from '../layouts/BaseLayout.astro';

const infographics = [
  {
    id: 'waste-types',
    title: 'Jenis-Jenis Sampah',
    subtitle: 'Kenali perbedaan sampah organik, anorganik, dan B3',
    items: [
      { label: 'Organik', pct: 60, color: '#52B788', emoji: '🌿', example: 'Sisa makanan, daun' },
      { label: 'Plastik', pct: 15, color: '#60a5fa', emoji: '🧴', example: 'Botol, kantong plastik' },
      { label: 'Kertas', pct: 12, color: '#fbbf24', emoji: '📄', example: 'Koran, karton' },
      { label: 'Logam', pct: 8, color: '#f87171', emoji: '🥫', example: 'Kaleng, besi' },
      { label: 'Lainnya', pct: 5, color: '#a78bfa', emoji: '🗑️', example: 'Karet, tekstil' },
    ],
  },
];

const wasteSteps = [
  { num: '1', icon: '🏠', title: 'Pilah di Rumah', desc: 'Sediakan 3 tempat sampah: organik (hijau), anorganik (kuning), dan residu (abu-abu).', color: 'border-green-700/40 bg-green-900/20' },
  { num: '2', icon: '🗑️', title: 'Gunakan Wadah Tepat', desc: 'Pastikan setiap wadah tertutup rapat untuk mencegah bau dan penyebaran penyakit.', color: 'border-blue-700/40 bg-blue-900/20' },
  { num: '3', icon: '📦', title: 'Kelola Secara Berkala', desc: 'Olah sampah organik menjadi kompos. Setor sampah anorganik ke bank sampah terdekat.', color: 'border-yellow-700/40 bg-yellow-900/20' },
  { num: '4', icon: '♻️', title: 'Daur Ulang', desc: 'Bawa sampah anorganik bersih ke pengepul atau drop point daur ulang terdekat.', color: 'border-purple-700/40 bg-purple-900/20' },
];

const impacts = [
  { icon: '🌊', title: 'Pencemaran Air', pct: 78, color: '#60a5fa', desc: 'Sampah yang tidak terkelola mencemari sungai dan laut' },
  { icon: '🌫️', title: 'Polusi Udara', pct: 65, color: '#f87171', desc: 'Pembakaran sampah menghasilkan gas berbahaya' },
  { icon: '🐟', title: 'Dampak Biota Laut', pct: 83, color: '#34d399', desc: 'Sampah plastik mengancam kehidupan laut' },
  { icon: '🏥', title: 'Risiko Kesehatan', pct: 70, color: '#fbbf24', desc: 'Sampah liar menjadi sarang penyakit' },
];
---

<BaseLayout title="Infografis" description="Infografis edukasi pemilahan sampah, komposisi limbah Indonesia, dan langkah pengelolaan yang benar.">

  <!-- Hero -->
  <section class="pt-32 pb-12 relative overflow-hidden">
    <div class="absolute top-0 left-0 w-96 h-96 bg-primary-600/10 rounded-full blur-3xl -translate-y-1/2 -translate-x-1/2"></div>
    <div class="section-container relative">
      <div class="max-w-2xl" data-aos>
        <span class="section-badge">Data & Visual</span>
        <h1 class="section-heading text-white mt-6">
          Infografis <span class="gradient-text italic">Sampah</span>
        </h1>
        <p class="text-gray-400 text-lg mt-4 leading-relaxed">
          Visualisasi data tentang komposisi sampah Indonesia, langkah pemilahan yang benar, dan dampak lingkungan dari sampah yang tidak terkelola.
        </p>
      </div>
    </div>
  </section>

  <!-- Komposisi Sampah -->
  <section class="py-16">
    <div class="section-container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <!-- Chart donut (CSS only) -->
        <div class="card-glass p-8" data-aos>
          <h2 class="text-white font-semibold text-2xl mb-2">Komposisi Sampah Indonesia</h2>
          <p class="text-gray-500 text-sm mb-8">Berdasarkan data KLHK 2023</p>

          <!-- Donut chart via conic-gradient -->
          <div class="flex flex-col md:flex-row gap-8 items-center">
            <div class="relative flex-shrink-0">
              <div
                class="w-48 h-48 rounded-full"
                style="background: conic-gradient(#52B788 0% 60%, #60a5fa 60% 75%, #fbbf24 75% 87%, #f87171 87% 95%, #a78bfa 95% 100%);"
              ></div>
              <div class="absolute inset-6 bg-[#0f1a14] rounded-full flex items-center justify-center">
                <span class="text-white text-xs text-center font-medium leading-tight">Total<br/><span class="text-2xl font-serif text-primary-400">67jt</span><br/>ton/thn</span>
              </div>
            </div>

            <div class="flex-1 space-y-3">
              {infographics[0].items.map((item) => (
                <div class="flex items-center gap-3">
                  <div class="w-3 h-3 rounded-full flex-shrink-0" style={`background:${item.color}`}></div>
                  <div class="flex-1">
                    <div class="flex items-center justify-between mb-1">
                      <span class="text-gray-300 text-sm">{item.emoji} {item.label}</span>
                      <span class="text-white font-semibold text-sm">{item.pct}%</span>
                    </div>
                    <div class="h-1.5 bg-white/10 rounded-full overflow-hidden">
                      <div
                        class="h-full rounded-full bar-fill"
                        style={`width: 0%; background: ${item.color}; transition: width 1.5s ease;`}
                        data-width={`${item.pct}%`}
                      ></div>
                    </div>
                    <p class="text-gray-600 text-xs mt-1">{item.example}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Dampak Lingkungan -->
        <div class="space-y-4" data-aos data-aos-delay="200">
          <h2 class="text-white font-semibold text-2xl mb-6">Dampak Sampah Tak Terkelola</h2>
          {impacts.map((imp, i) => (
            <div class="card-glass p-6">
              <div class="flex items-center gap-4 mb-3">
                <span class="text-2xl">{imp.icon}</span>
                <div class="flex-1">
                  <div class="flex items-center justify-between mb-1">
                    <span class="text-white font-medium">{imp.title}</span>
                    <span class="font-semibold text-sm" style={`color:${imp.color}`}>{imp.pct}%</span>
                  </div>
                  <div class="h-2 bg-white/10 rounded-full overflow-hidden">
                    <div
                      class="h-full rounded-full bar-fill"
                      style={`width:0%; background:${imp.color}; transition: width 1.5s ease ${i * 0.2}s`}
                      data-width={`${imp.pct}%`}
                    ></div>
                  </div>
                </div>
              </div>
              <p class="text-gray-500 text-xs pl-10">{imp.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- 4 Langkah Pemilahan -->
  <section class="py-16 border-y border-white/5">
    <div class="section-container">
      <div class="text-center mb-12" data-aos>
        <span class="section-badge">Panduan Praktis</span>
        <h2 class="section-heading text-white mt-6">4 Langkah <span class="gradient-text italic">Mudah Memilah Sampah</span></h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {wasteSteps.map((step, i) => (
          <div
            class={`relative rounded-2xl border p-8 ${step.color} group hover:scale-105 transition-transform duration-300`}
            data-aos
            data-aos-delay={String(i * 100)}
          >
            <div class="absolute -top-4 -left-4 w-10 h-10 rounded-full bg-gradient-to-br from-primary-500 to-primary-700 flex items-center justify-center text-white font-bold shadow-lg">
              {step.num}
            </div>
            <div class="text-4xl mb-4 mt-2">{step.icon}</div>
            <h3 class="text-white font-semibold text-lg mb-3">{step.title}</h3>
            <p class="text-gray-400 text-sm leading-relaxed">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Fakta Cepat -->
  <section class="py-16">
    <div class="section-container">
      <div class="text-center mb-12" data-aos>
        <span class="section-badge">Tahukah Kamu?</span>
        <h2 class="section-heading text-white mt-6">Fakta <span class="gradient-text italic">Mengejutkan</span></h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          { emoji: '🥤', fact: '1 botol plastik butuh 450 tahun untuk terurai di alam.', source: 'UNEP 2023' },
          { emoji: '🐋', fact: 'Paus ditemukan mati dengan 40kg sampah plastik di perutnya di perairan Indonesia.', source: 'WWF Indonesia' },
          { emoji: '🌏', fact: 'Indonesia peringkat 5 penyumbang sampah plastik terbesar ke lautan dunia.', source: 'Ocean Conservancy' },
          { emoji: '♻️', fact: 'Mendaur ulang 1 ton kertas menyelamatkan 17 pohon dan 26.000 liter air.', source: 'KLHK 2023' },
          { emoji: '💰', fact: 'Sampah yang dipilah dengan baik dapat menghasilkan Rp2-5 juta per bulan dari bank sampah.', source: 'Bank Sampah Nasional' },
          { emoji: '🌱', fact: 'Kompos dari 1 kg sampah organik dapat menyuburkan 5 m² lahan pertanian.', source: 'Kementan RI' },
        ].map((f, i) => (
          <div class="card-glass p-6" data-aos data-aos-delay={String((i % 3) * 100)}>
            <div class="text-3xl mb-4">{f.emoji}</div>
            <p class="text-gray-300 leading-relaxed mb-3">{f.fact}</p>
            <span class="text-xs text-primary-500 font-medium">— {f.source}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  // Animate progress bars when in view
  const bars = document.querySelectorAll('.bar-fill');
  const barObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        const el = entry.target as HTMLElement;
        el.style.width = el.dataset.width || '0%';
        barObserver.unobserve(el);
      }
    });
  }, { threshold: 0.3 });
  bars.forEach((bar) => barObserver.observe(bar));
</script>
